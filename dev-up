#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
RUNTIME_DIR="${HOME}/.agent-message"
BIN_DIR="${RUNTIME_DIR}/bin"
LOG_DIR="${RUNTIME_DIR}/logs"
UPLOAD_DIR="${RUNTIME_DIR}/uploads"
SERVER_BIN="${BIN_DIR}/agent-message-server"
SERVER_LOG="${LOG_DIR}/server.log"
GATEWAY_LOG="${LOG_DIR}/gateway.log"
TUNNEL_LOG="${LOG_DIR}/named-tunnel.log"
SERVER_PIDFILE="${RUNTIME_DIR}/server.pid"
GATEWAY_PIDFILE="${RUNTIME_DIR}/gateway.pid"
TUNNEL_PIDFILE="${RUNTIME_DIR}/named-tunnel.pid"
INCLUDE_TUNNEL=0

for arg in "$@"; do
  case "$arg" in
    --with-tunnel|--all)
      INCLUDE_TUNNEL=1
      ;;
    *)
      echo "usage: ./dev-up [--with-tunnel]" >&2
      exit 1
      ;;
  esac
done

wait_for_http() {
  local url="$1"
  local label="$2"

  for _ in {1..40}; do
    if curl -fsS "$url" >/dev/null 2>&1; then
      return 0
    fi
    sleep 0.5
  done

  echo "${label} did not become ready: ${url}" >&2
  return 1
}

start_process() {
  local log_file="$1"
  local pid_file="$2"
  shift 2

  : > "$log_file"
  python3 - "$log_file" "$@" >"$pid_file" <<'PY'
import subprocess
import sys

log_path = sys.argv[1]
command = sys.argv[2:]

with open(log_path, "ab", buffering=0) as log_file:
    process = subprocess.Popen(
        command,
        stdin=subprocess.DEVNULL,
        stdout=log_file,
        stderr=log_file,
        start_new_session=True,
    )

print(process.pid)
PY
}

mkdir -p "$BIN_DIR" "$LOG_DIR" "$UPLOAD_DIR"

"${ROOT_DIR}/dev-stop" $([[ "$INCLUDE_TUNNEL" -eq 1 ]] && printf '%s' '--with-tunnel')

if [[ ! -d "${ROOT_DIR}/web/node_modules" ]]; then
  (cd "${ROOT_DIR}/web" && npm ci)
fi

(cd "${ROOT_DIR}/web" && npm run build)
(cd "${ROOT_DIR}/server" && go build -o "$SERVER_BIN" .)

start_process \
  "$SERVER_LOG" \
  "$SERVER_PIDFILE" \
  env \
  SERVER_ADDR=:18080 \
  DB_DRIVER=sqlite \
  SQLITE_DSN="${RUNTIME_DIR}/agent_message.sqlite" \
  UPLOAD_DIR="$UPLOAD_DIR" \
  CORS_ALLOWED_ORIGINS=* \
  "$SERVER_BIN"

wait_for_http "http://127.0.0.1:18080/healthz" "server"

start_process \
  "$GATEWAY_LOG" \
  "$GATEWAY_PIDFILE" \
  env \
  AGENT_GATEWAY_HOST=127.0.0.1 \
  AGENT_GATEWAY_PORT=8788 \
  AGENT_API_ORIGIN=http://127.0.0.1:18080 \
  AGENT_WEB_DIST="${ROOT_DIR}/web/dist" \
  node "${ROOT_DIR}/deploy/agent_gateway.mjs"

wait_for_http "http://127.0.0.1:8788" "gateway"

if [[ "$INCLUDE_TUNNEL" -eq 1 ]]; then
  start_process \
    "$TUNNEL_LOG" \
    "$TUNNEL_PIDFILE" \
    cloudflared tunnel --config "${ROOT_DIR}/deploy/agent_tunnel_config.yml" run agent-namjaeyoun-com

  for _ in {1..40}; do
    if grep -q "Registered tunnel connection" "$TUNNEL_LOG" 2>/dev/null; then
      break
    fi
    sleep 0.5
  done
fi

echo "Local server is up."
echo "API:     http://127.0.0.1:18080"
echo "Web:     http://127.0.0.1:8788"
echo "Logs:    ${SERVER_LOG} ${GATEWAY_LOG}"
if [[ "$INCLUDE_TUNNEL" -eq 1 ]]; then
  echo "Tunnel:  https://agent.namjaeyoun.com"
  echo "Tunnel log: ${TUNNEL_LOG}"
fi
