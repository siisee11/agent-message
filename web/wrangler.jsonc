{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "agent-message-web",
  "main": "./worker/index.js",
  "compatibility_date": "2026-04-21",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*", "/static/uploads/*"]
  }
}
