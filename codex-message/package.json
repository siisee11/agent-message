{
  "name": "codex-message",
  "version": "0.6.27",
  "description": "Codex wrapper for agent-message on macOS",
  "type": "module",
  "bin": {
    "codex-message": "npm/bin/codex-message.mjs"
  },
  "files": [
    "README.md",
    "npm/bin",
    "npm/runtime"
  ],
  "scripts": {
    "prepare:npm-bundle": "node ../scripts/sync-wrapper-package-versions.mjs && node ./scripts/prepare-npm-bundle.mjs",
    "prepack": "node ../scripts/sync-wrapper-package-versions.mjs && node ./scripts/prepare-npm-bundle.mjs",
    "pack:dry-run": "npm pack --dry-run"
  },
  "engines": {
    "node": ">=18"
  },
  "os": [
    "darwin"
  ],
  "cpu": [
    "arm64",
    "x64"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/siisee11/agent-message.git",
    "directory": "codex-message"
  }
}
